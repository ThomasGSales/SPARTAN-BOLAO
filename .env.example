# Copie para .env e ajuste. NÃO commite o .env real.

# --- Banco de dados ---
POSTGRES_DB=spartan
POSTGRES_USER=spartan
POSTGRES_PASSWORD=troque-por-uma-senha-forte

# --- Segurança ---
# Gere com: openssl rand -base64 48
JWT_SECRET=gere-um-segredo-forte-de-256-bits-aqui

# --- Login com Google (OAuth2) ---
# Crie em https://console.cloud.google.com/apis/credentials
# Use só o Client ID (fluxo GIS/ID-token); o secret fica vazio de propósito.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Football-data.org (jogos + placares da Copa 2026) ---
# Chave grátis em https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=

# --- Admins ---
# E-mails (separados por vírgula) que recebem papel ADMIN ao entrar.
# Admins podem forçar o sync e lançar placar.
ADMIN_EMAILS=

# --- Produção (só usado com docker-compose.prod.yml) ---
# Domínio (ex.: DuckDNS) que aponta por DNS para o IP público da VPS.
# O Caddy emite o certificado HTTPS automaticamente para ele.
DOMAIN=
